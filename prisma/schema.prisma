generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agreement {
  forestFileId               String                     @id @map("forest_file_id") @db.VarChar(9)
  agreementStartDate         DateTime                   @map("agreement_start_date") @db.Timestamptz(6)
  agreementEndDate           DateTime                   @map("agreement_end_date") @db.Timestamptz(6)
  agreementTypeId            Int                        @map("agreement_type_id")
  zoneId                     Int                        @map("zone_id")
  createdAt                  DateTime                   @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                   @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @updatedAt @map("updated_at") @db.Timestamptz(6)
  retired                    Boolean?                   @default(false)
  usageStatus                Int?                       @map("usage_status")
  percentageUse              Decimal?                   @map("percentage_use") @db.Decimal(10, 2)
  hasCurrentSchedule         Int?                       @map("has_current_schedule")
  exemptionStatus            String                     @default("NOT_EXEMPTED") @map("exemption_status") @db.VarChar(32)
  agreementType              AgreementType              @relation(fields: [agreementTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "agreement_agreement_type_id_foreign")
  agreement_exemption_status agreement_exemption_status @relation(fields: [exemptionStatus], references: [code], onDelete: NoAction, onUpdate: NoAction, map: "agreement_exemption_status_fk")
  zone                       Zone                       @relation(fields: [zoneId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "agreement_zone_id_foreign")
  clientAgreements           ClientAgreement[]
  exemptions                 Exemption[]
  livestockIdentifiers       LivestockIdentifier[]
  plans                      Plan[]
  ref_usage                  ref_usage[]

  @@index([forestFileId], map: "agreement_forest_file_id_index")
  @@map("agreement")
}

model AgreementType {
  id          Int         @id @default(autoincrement())
  code        String
  description String
  active      Boolean     @default(true)
  created_at  DateTime    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  updated_at  DateTime    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  agreements  Agreement[]

  @@map("ref_agreement_type")
}

model Zone {
  id           Int         @id @default(autoincrement())
  code         String
  description  String
  districtId   Int         @map("district_id")
  user_id      Int?
  created_at   DateTime    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  updated_at   DateTime    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  agreements   Agreement[]
  district     District    @relation(fields: [districtId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ref_zone_district_id_foreign")
  user_account User?       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ref_zone_user_id_foreign")

  @@index([code], map: "ref_zone_code_index")
  @@map("ref_zone")
}

model District {
  id           Int      @id @default(autoincrement())
  code         String   @unique(map: "ref_district_code_unique")
  description  String
  created_at   DateTime @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  updated_at   DateTime @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  user_id      Int?
  user_account User?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  zones        Zone[]

  @@index([code], map: "ref_district_code_index")
  @@map("ref_district")
}

model Client {
  clientNumber                 String             @id @map("client_number") @db.VarChar(8)
  name                         String
  licensee_start_date          DateTime?          @db.Timestamptz(6)
  licensee_end_date            DateTime?          @db.Timestamptz(6)
  createdAt                    DateTime           @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updatedAt                    DateTime           @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @updatedAt @map("updated_at") @db.Timestamptz(6)
  forest_file_client_type_code String?
  location_codes               String[]           @db.VarChar(2)
  clientAgreements             ClientAgreement[]
  plan_confirmation            PlanConfirmation[]
  userClientLinks              UserClientLink[]

  @@index([clientNumber], map: "ref_client_client_number_index")
  @@map("ref_client")
}

model ClientAgreement {
  id           Int        @id @default(autoincrement())
  agreementId  String     @map("agreement_id") @db.VarChar(9)
  clientTypeId Int        @map("client_type_id")
  createdAt    DateTime   @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @updatedAt @map("updated_at") @db.Timestamptz(6)
  agentId      Int?       @map("agent_id")
  clientId     String?    @map("client_id") @db.VarChar
  user_account User?      @relation(fields: [agentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  agreement    Agreement  @relation(fields: [agreementId], references: [forestFileId], onDelete: NoAction, onUpdate: NoAction, map: "client_agreement_agreement_id_foreign")
  client       Client?    @relation(fields: [clientId], references: [clientNumber], onDelete: NoAction, onUpdate: NoAction)
  clientType   ClientType @relation(fields: [clientTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "client_agreement_client_type_id_foreign")

  @@index([agreementId], map: "client_agreement_agreement_id_index")
  @@map("client_agreement")
}

model ClientType {
  id               Int               @id @default(autoincrement())
  code             String            @db.VarChar(1)
  description      String
  active           Boolean           @default(true)
  created_at       DateTime          @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  updated_at       DateTime          @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  clientAgreements ClientAgreement[]

  @@map("ref_client_type")
}

model User {
  id                                            Int                        @id @default(autoincrement())
  username                                      String                     @unique(map: "user_account_username_unique")
  givenName                                     String?                    @map("given_name")
  familyName                                    String?                    @map("family_name")
  email                                         String
  phone_number                                  String?
  pia_seen                                      Boolean                    @default(false)
  active                                        Boolean                    @default(true)
  lastLoginAt                                   DateTime?                  @map("last_login_at") @db.Timestamptz(6)
  createdAt                                     DateTime                   @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updatedAt                                     DateTime                   @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @updatedAt @map("updated_at") @db.Timestamptz(6)
  temp_backup_username_for_migration            String?
  ssoId                                         String?                    @map("sso_id") @db.VarChar(255)
  role_id                                       Int?
  client_agreement                              ClientAgreement[]
  exemption_exemption_approved_byTouser_account Exemption[]                @relation("exemption_approved_byTouser_account")
  exemption_exemption_user_idTouser_account     Exemption[]                @relation("exemption_user_idTouser_account")
  exemption_attachment                          exemption_attachment[]
  exemption_status_history                      exemption_status_history[]
  createdPlans                                  Plan[]
  plan_confirmation                             PlanConfirmation[]
  plan_file                                     PlanFile[]
  plan_status_history                           PlanStatusHistory[]
  ref_district                                  District[]
  ref_zone                                      Zone[]
  roles                                         roles?                     @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "role_foreign_key")
  userClientLinks                               UserClientLink[]
  user_districts                                user_districts[]
  user_feedback                                 user_feedback[]

  @@map("user_account")
}

model UserClientLink {
  id        Int                  @id(map: "active_client_account_pkey") @default(autoincrement())
  userId    Int                  @map("user_id")
  type      client_account_type? @default(owner)
  active    Boolean
  createdAt DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime?            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  clientId  String?              @map("client_id") @db.VarChar
  client    Client?              @relation(fields: [clientId], references: [clientNumber], onDelete: NoAction, onUpdate: NoAction)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_client_link")
}

model Plan {
  id                          Int                        @id @default(autoincrement())
  agreementId                 String                     @map("agreement_id") @db.VarChar(9)
  statusId                    Int                        @map("status_id")
  amendmentTypeId             Int?                       @map("amendment_type_id")
  creatorId                   Int                        @map("creator_id")
  rangeName                   String                     @map("range_name")
  altBusinessName             String?                    @map("alt_business_name")
  planStartDate               DateTime?                  @map("plan_start_date") @db.Timestamptz(6)
  planEndDate                 DateTime?                  @map("plan_end_date") @db.Timestamptz(6)
  notes                       String?
  createdAt                   DateTime                   @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime                   @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @updatedAt @map("updated_at") @db.Timestamptz(6)
  uploaded                    Boolean                    @default(false)
  effectiveAt                 DateTime?                  @map("effective_at") @db.Timestamptz(6)
  submittedAt                 DateTime?                  @map("submitted_at") @db.Timestamptz(6)
  canonicalId                 Int?                       @map("canonical_id")
  isRestored                  Boolean?                   @default(false) @map("is_restored")
  conditions                  String?
  proposedConditions          String?                    @map("proposed_conditions")
  extensionStatus             Int?                       @map("extension_status")
  replacementOf               Int?                       @map("replacement_of")
  extensionRequiredVotes      Int?                       @default(0) @map("extension_required_votes")
  extensionReceivedVotes      Int?                       @default(0) @map("extension_received_votes")
  extensionDate               DateTime?                  @map("extension_date") @db.Timestamp(6)
  extensionRejectedBy         Int?                       @map("extension_rejected_by")
  replacementPlanId           Int?                       @map("replacement_plan_id")
  livestockDistributionDetail String?                    @map("livestock_distribution_detail")
  additional_requirement      additional_requirement[]
  grazingSchedules            GrazingSchedule[]
  invasive_plant_checklist    invasive_plant_checklist?
  management_consideration    management_consideration[]
  minister_issue              minister_issue[]
  pastures                    Pasture[]
  agreement                   Agreement                  @relation(fields: [agreementId], references: [forestFileId], onDelete: NoAction, onUpdate: NoAction, map: "plan_agreement_id_foreign")
  ref_amendment_type          ref_amendment_type?        @relation(fields: [amendmentTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "plan_amendment_type_id_foreign")
  creator                     User                       @relation(fields: [creatorId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "plan_creator_id_foreign")
  status                      PlanStatus                 @relation(fields: [statusId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "plan_status_id_foreign")
  confirmations               PlanConfirmation[]
  extensions                  PlanExtensionRequest[]
  planFiles                   PlanFile[]
  plan_snapshot               plan_snapshot[]
  plan_status_history         PlanStatusHistory[]
  plan_version                plan_version[]

  @@map("plan")
}

model PlanStatus {
  id                                                                           Int                 @id @default(autoincrement())
  code                                                                         String              @unique(map: "ref_plan_status_code_unique")
  name                                                                         String
  active                                                                       Boolean             @default(true)
  description_full                                                             String?
  description_short                                                            String?
  created_at                                                                   DateTime            @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  updated_at                                                                   DateTime            @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  plans                                                                        Plan[]
  plan_snapshot                                                                plan_snapshot[]
  plan_status_history_plan_status_history_from_plan_status_idToref_plan_status PlanStatusHistory[] @relation("plan_status_history_from_plan_status_idToref_plan_status")
  plan_status_history_plan_status_history_to_plan_status_idToref_plan_status   PlanStatusHistory[] @relation("plan_status_history_to_plan_status_idToref_plan_status")

  @@index([code], map: "ref_plan_status_code_index")
  @@map("ref_plan_status")
}

model PlanStatusHistory {
  id                                                                       Int         @id @default(autoincrement())
  planId                                                                   Int         @map("plan_id")
  fromPlanStatusId                                                         Int?        @map("from_plan_status_id")
  toPlanStatusId                                                           Int         @map("to_plan_status_id")
  userId                                                                   Int         @map("user_id")
  note                                                                     String
  createdAt                                                                DateTime    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updated_at                                                               DateTime    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  ref_plan_status_plan_status_history_from_plan_status_idToref_plan_status PlanStatus? @relation("plan_status_history_from_plan_status_idToref_plan_status", fields: [fromPlanStatusId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "plan_status_history_from_plan_status_id_foreign")
  plan                                                                     Plan        @relation(fields: [planId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "plan_status_history_plan_id_foreign")
  ref_plan_status_plan_status_history_to_plan_status_idToref_plan_status   PlanStatus  @relation("plan_status_history_to_plan_status_idToref_plan_status", fields: [toPlanStatusId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "plan_status_history_to_plan_status_id_foreign")
  user_account                                                             User        @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "plan_status_history_user_id_foreign")

  @@map("plan_status_history")
}

model GrazingSchedule {
  id                        Int                         @id @default(autoincrement())
  planId                    Int                         @map("plan_id")
  year                      Int                         @db.SmallInt
  narative                  String?
  createdAt                 DateTime                    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @updatedAt @map("updated_at") @db.Timestamptz(6)
  canonical_id              Int?
  sort_by                   String?                     @db.VarChar
  sort_order                schedule_sort_order?
  plan                      Plan                        @relation(fields: [planId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "grazing_schedule_plan_id_foreign")
  entries                   GrazingScheduleEntry[]
  haycutting_schedule_entry haycutting_schedule_entry[]

  @@index([planId], map: "grazing_schedule_plan_id_index")
  @@index([year], map: "grazing_schedule_year_index")
  @@map("grazing_schedule")
}

model GrazingScheduleEntry {
  id                Int             @id @default(autoincrement())
  livestock_type_id Int
  grazingScheduleId Int             @map("grazing_schedule_id")
  pastureId         Int             @map("pasture_id")
  date_in           DateTime?       @db.Timestamptz(6)
  date_out          DateTime?       @db.Timestamptz(6)
  grace_days        Int?
  livestock_count   Int?
  created_at        DateTime        @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  updated_at        DateTime        @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  canonical_id      Int?
  crown_au_ms       Int?            @default(0)
  grazingSchedule   GrazingSchedule @relation(fields: [grazingScheduleId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "grazing_schedule_entry_grazing_schedule_id_foreign")
  ref_livestock     ref_livestock   @relation(fields: [livestock_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "grazing_schedule_entry_livestock_type_id_foreign")
  pasture           Pasture         @relation(fields: [pastureId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "grazing_schedule_entry_pasture_id_foreign")

  @@index([grazingScheduleId], map: "grazing_schedule_entry_grazing_schedule_id_index")
  @@index([livestock_type_id], map: "grazing_schedule_entry_livestock_type_id_index")
  @@index([pastureId], map: "grazing_schedule_entry_pasture_id_index")
  @@map("grazing_schedule_entry")
}

model Pasture {
  id                        Int                         @id @default(autoincrement())
  planId                    Int                         @map("plan_id")
  name                      String
  allowable_aum             Int?
  grace_days                Int?
  pld_percent               Float?                      @db.Real
  notes                     String?
  created_at                DateTime                    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  updated_at                DateTime                    @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  canonical_id              Int?
  grazingEntries            GrazingScheduleEntry[]
  haycutting_schedule_entry haycutting_schedule_entry[]
  minister_issue_pasture    minister_issue_pasture[]
  plan                      Plan                        @relation(fields: [planId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "pasture_plan_id_foreign")
  plantCommunities          PlantCommunity[]

  @@index([planId], map: "pasture_plan_id_index")
  @@map("pasture")
}

model PlantCommunity {
  id                            Int                            @id @default(autoincrement())
  community_type_id             Int
  elevation_id                  Int?
  pastureId                     Int                            @map("pasture_id")
  purpose_of_action             String
  approved                      Boolean                        @default(false)
  name                          String?                        @default("")
  aspect                        String?
  url                           String?
  notes                         String?
  range_readiness_day           Int?
  range_readiness_month         Int?
  range_readiness_note          String?
  created_at                    DateTime                       @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  updated_at                    DateTime                       @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  shrub_use                     Float?                         @db.Real
  canonical_id                  Int?
  indicators                    IndicatorPlant[]
  monitoring_area               monitoring_area[]
  ref_plant_community_type      ref_plant_community_type       @relation(fields: [community_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "plant_community_community_type_id_foreign")
  ref_plant_community_elevation ref_plant_community_elevation? @relation(fields: [elevation_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "plant_community_elevation_id_foreign")
  pasture                       Pasture                        @relation(fields: [pastureId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "plant_community_pasture_id_foreign")
  plant_community_action        plant_community_action[]

  @@map("plant_community")
}

model IndicatorPlant {
  id                Int                @id @default(autoincrement())
  plant_species_id  Int?
  plantCommunityId  Int                @map("plant_community_id")
  criteria          String
  name              String?
  value             Float?             @db.Real
  created_at        DateTime           @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  updated_at        DateTime           @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  canonical_id      Int?
  plantCommunity    PlantCommunity     @relation(fields: [plantCommunityId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "indicator_plant_plant_community_id_foreign")
  ref_plant_species ref_plant_species? @relation(fields: [plant_species_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "indicator_plant_plant_species_id_foreign")

  @@map("indicator_plant")
}

model PlanFile {
  id           Int    @id @default(autoincrement())
  name         String @db.VarChar
  url          String @db.VarChar
  type         String @db.VarChar
  access       String @default("staff_only") @db.VarChar
  planId       Int    @map("plan_id")
  user_id      Int
  plan         Plan   @relation(fields: [planId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_account User   @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("plan_file")
}

model PlanExtensionRequest {
  id                 Int      @id @default(autoincrement())
  planId             Int?     @map("plan_id")
  clientId           String?  @map("client_id") @db.VarChar
  userId             Int?     @map("user_id")
  email              String?
  requestedExtension Boolean? @map("requested_extension")
  createdAt          DateTime @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @updatedAt @map("updated_at") @db.Timestamptz(6)
  plan               Plan?    @relation(fields: [planId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("plan_extension_requests")
}

model PlanConfirmation {
  id                     Int      @id @default(autoincrement())
  planId                 Int      @map("plan_id")
  confirmed              Boolean  @default(false)
  createdAt              DateTime @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updated_at             DateTime @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  user_id                Int?
  is_own_signature       Boolean  @default(true)
  clientId               String?  @map("client_id") @db.VarChar
  is_manual_confirmation Boolean?
  ref_client             Client?  @relation(fields: [clientId], references: [clientNumber], onDelete: NoAction, onUpdate: NoAction)
  plan                   Plan     @relation(fields: [planId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "plan_confirmation_plan_id_foreign")
  user_account           User?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([planId], map: "plan_confirmation_plan_id_index")
  @@map("plan_confirmation")
}

model LivestockIdentifier {
  id                                Int                               @id @default(autoincrement())
  description                       String?
  image_ref                         String?
  accepted                          Boolean                           @default(false)
  livestock_identifier_location_id  Int
  livestock_identifier_type_id      Int
  agreementId                       String                            @map("agreement_id") @db.VarChar(9)
  createdAt                         DateTime                          @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @map("created_at") @db.Timestamptz(6)
  updated_at                        DateTime                          @default(dbgenerated("('now'::text)::timestamp(3) with time zone")) @db.Timestamptz(6)
  agreement                         Agreement                         @relation(fields: [agreementId], references: [forestFileId], onDelete: NoAction, onUpdate: NoAction, map: "livestock_identifier_agreement_id_foreign")
  ref_livestock_identifier_location ref_livestock_identifier_location @relation(fields: [livestock_identifier_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "livestock_identifier_livestock_identifier_location_id_foreign")
  ref_livestock_identifier_type     ref_livestock_identifier_type     @relation(fields: [livestock_identifier_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "livestock_identifier_livestock_identifier_type_id_foreign")

  @@map("livestock_identifier")
}

model Exemption {
  id                                               Int                        @id @default(autoincrement())
  agreementId                                      String                     @map("agreement_id") @db.VarChar(9)
  start_date                                       DateTime                   @db.Date
  end_date                                         DateTime                   @db.Date
  reason                                           String?
  justification_text                               String?
  status                                           String                     @default("Draft") @db.VarChar(32)
  user_id                                          Int
  approved_by                                      Int?
  approval_date                                    DateTime?                  @db.Timestamptz(6)
  createdAt                                        DateTime?                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                        DateTime?                  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  agreement                                        Agreement                  @relation(fields: [agreementId], references: [forestFileId], onDelete: Cascade, onUpdate: NoAction)
